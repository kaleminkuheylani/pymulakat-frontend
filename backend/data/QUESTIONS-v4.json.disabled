              true,
              "prime_teen"
            ],
            [
              1,
              false,
              "below_two"
            ],
            [
              0,
              false,
              "zero_edge"
            ]
          ]
        },
        "expected": "all_pass"
      },
      {
        "input": {
          "cases": [
            [
              9,
              false,
              "perfect_square"
            ]
          ]
        },
        "expected": "passes"
      },
      {
        "input": {
          "cases": [
            [
              7,
              true,
              "single_digit_prime"
            ],
            [
              11,
              true,
              "eleven"
            ],
            [
              13,
              true,
              "thirteen"
            ]
          ]
        },
        "expected": "all_pass"
      },
      {
        "input": {
          "cases": [
            [
              25,
              false,
              "perfect_square_5"
            ],
            [
              49,
              false,
              "perfect_square_7"
            ]
          ]
        },
        "expected": "passes"
      },
      {
        "input": {
          "cases": [
            [
              -5,
              false,
              "negative"
            ]
          ]
        },
        "expected": "passes"
      }
