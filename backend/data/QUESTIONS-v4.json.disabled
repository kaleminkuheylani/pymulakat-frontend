    "description": "Bir fonksiyon icin pytest parametrized test yaz. Her test case icin aciklayici ID'ler koy (smallest_prime, even_composite gibi).",
    "starter_code": "import pytest\n\ndef is_prime(n):\n    if n < 2:\n        return False\n    for i in range(2, int(n ** 0.5) + 1):\n        if n % i == 0:\n            return False\n    return True\n\n@pytest.mark.parametrize('n,expected,case_id', [\n    # Buraya test case'ler\n])\ndef test_is_prime(n, expected, case_id):\n    assert is_prime(n) == expected\n",
    "test_cases": [
      {
