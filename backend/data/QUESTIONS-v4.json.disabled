          "strategy": "lower",
          "text": "HELLO"
        },
        "expected": "hello"
      },
      {
        "input": {
          "strategy": "swap",
          "text": "Hello"
        },
        "expected": "hELLO"
      },
      {
        "input": {
          "strategy": "reverse",
          "text": "abc"
        },
        "expected": "cba"
      },
