    "starter_code": "class KthLargest:\n    def __init__(self, k: int, nums: list):\n        # Hangi yapı? n büyük, k küçük → O(log k) erişim gerekli\n        pass\n\n    def add(self, val: int) -> int:\n        # Kth largest = en küçük olan (top K'nın)\n        pass",
