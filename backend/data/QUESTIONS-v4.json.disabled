    "id": 1090,
    "title": "Observer Pattern (Event Emitter)",
    "category": "design-patterns",
    "level": "advanced",
    "description": "Event emitter: subscribe(callback) → unsubscribe_token, emit(event) tüm subscriber'ları çağırır. Token ile unsubscribe.",
    "starter_code": "class EventEmitter:\n    def __init__(self):\n        pass\n\n    def subscribe(self, callback):\n        # token dön (unsubscribe için)\n        pass\n\n    def emit(self, event):\n        pass\n\n    def unsubscribe(self, token):\n        pass",
    "test_cases": [
      {
        "input": {
          "op": "subscribe_emit",
          "n_subs": 1,
          "events": [
            "e1"
          ]
        },
