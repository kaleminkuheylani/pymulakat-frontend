# ═══════════════════════════════════════════════════════════════
# PythonMulakat — Environment Variables
# ═══════════════════════════════════════════════════════════════
# Bu dosyayı .env olarak kopyala ve gerçek değerleri doldur.
# Asla gerçek .env dosyasını commit etme!
# ═══════════════════════════════════════════════════════════════

# ─── Frontend (Next.js) ────────────────────────────────────
# Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...your-anon-key...

# Backend FastAPI URL
# - Public URL (browser bundle'a inline edilir, NEXT_PUBLIC_*)
# - Internal URL (RSC'ler server'da kullanır, public DNS atlanır)
#   Production: docker-compose/k8s internal network
#   Local dev: aynı NEXT_PUBLIC_API_URL kullanılır (veya localhost)
NEXT_PUBLIC_API_URL=http://localhost:8000
INTERNAL_API_URL=http://localhost:8000

# Canonical site URL (sitemap, OG, JSON-LD)
NEXT_PUBLIC_SITE_URL=https://pythonmulakat.com

# ISR on-demand revalidation (2026-07-13)
# /api/revalidate endpoint'i bu secret ile korunuyor.
# Backend → frontend notify_nextjs_revalidate() aynı secret ile istek atar.
# Üretmek için: openssl rand -hex 32
REVALIDATE_SECRET=replace-with-strong-random-32-byte-hex

# ─── Backend (FastAPI) ─────────────────────────────────────
# Aynı Supabase projesi
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOi...same-as-frontend...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...service-role-key-DO-NOT-EXPOSE...

# ─── Supabase Dashboard'da Yapılacak Ayarlar ────────────────
# 1. Authentication → URL Configuration:
#    Site URL:    https://pythonmulakat.com
#    Redirect URLs:
#      - https://pythonmulakat.com/auth/callback
#      - http://localhost:3000/auth/callback   (dev)

# 2. Authentication → Providers:
#    - Email: KAPALI (sadece OAuth kullanılıyor)
#    - Google:  AÇIK — Client ID + Secret
#    - GitHub:  AÇIK — Client ID + Secret

# 3. profiles tablosuna yeni kolonlar (Supabase SQL Editor):
#    ALTER TABLE profiles ADD COLUMN IF NOT EXISTS is_verified BOOLEAN DEFAULT FALSE;
# 2026-07-14: AI Feedback (DeepSeek V3) — ücretsiz tier fallback.
# Kullanıcı kendi key'ini localStorage'da tutabilir (BYOK, öncelikli).
# Bu env sadece BYOK kullanmayan user'lar için fallback.
# Maliyet: ~/bin/bash.09/1M token — 1 feedback ≈ 3000 token = /bin/bash.0003
DEEPSEEK_API_KEY=

Get your key: https://platform.deepseek.com/api_keys
